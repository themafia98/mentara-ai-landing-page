---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { BLOG_CLUSTERS } from '../../content/blog-clusters';
import { localeHome, withBase } from '../../i18n';

const posts = (await getCollection('blog', (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const postById = new Map(posts.map((post) => [post.id, post] as const));
const clusters = BLOG_CLUSTERS.map((cluster) => ({
  ...cluster,
  posts: cluster.slugs.map((slug) => postById.get(slug)).filter(Boolean),
}));
---

<BaseLayout
  locale="en"
  title="Resources — Mentara"
  description="Interview prep resources from Mentara: comparison pages, behavioral prep, system design guidance, and senior-level interview strategy."
>
  <Nav locale="en" homeHref={localeHome('en')} />
  <main id="main" class="hub">
    <div class="container hub__inner">
      <p class="eyebrow">Resources</p>
      <h1 class="h2">Structured reading paths for technical interview prep.</h1>
      <p class="hub__intro">
        Not a random archive. These are grouped entry points for candidates comparing tools,
        practicing system design, tightening behavioral answers, or preparing for senior and
        staff loops.
      </p>

      <div class="hub__grid">
        {
          clusters.map((cluster) => (
            <section class="cluster">
              <h2 class="cluster__title">{cluster.title}</h2>
              <p class="cluster__lede">{cluster.lede}</p>
              <ul class="cluster__list">
                {cluster.posts.map((post) => (
                  <li class="cluster__item">
                    <a href={withBase(`blog/${post.id}`)}>
                      <strong>{post.data.title}</strong>
                      <span>{post.data.summary}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>
  </main>
  <Footer locale="en" />
</BaseLayout>

<style>
  .hub {
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .hub__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .hub__intro {
    color: var(--bone-dim);
    line-height: 1.7;
    max-width: 46rem;
  }
  .hub__grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .cluster {
    border: 1px solid var(--line);
    padding: 1.2rem;
    background: color-mix(in oklab, var(--ink-2) 52%, transparent);
  }
  .cluster__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: -0.02em;
  }
  .cluster__lede {
    margin-top: 0.5rem;
    color: var(--bone-dim);
    line-height: 1.65;
  }
  .cluster__list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    list-style: none;
  }
  .cluster__item a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .cluster__item strong {
    color: var(--bone);
  }
  .cluster__item span {
    color: var(--bone-dim);
    line-height: 1.55;
  }
  .cluster__item a:hover strong {
    color: var(--amber);
  }
  @media (max-width: 860px) {
    .hub__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
