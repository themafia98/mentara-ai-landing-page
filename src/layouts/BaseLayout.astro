---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/hanken-grotesk';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/600.css';
import '../styles/global.css';
import { SITE } from '../consts';
import { DEFAULT_LOCALE, LOCALES, getDict, localeUrl, withBase, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = getDict(locale);
const pageTitle = title ?? t.meta.title;
const pageDesc = description ?? t.meta.description;

// All asset paths go through the single `withBase` joiner — no ad-hoc base math here.
const origin = Astro.site ?? new URL(SITE.domain);
const canonical = new URL(Astro.url.pathname, origin).href;
const favicon = withBase('favicon.svg');
const ogImage = new URL(withBase(`og/${locale}.png`), origin).href;
const sitemapHref = withBase('sitemap-index.xml');
const rssHref = withBase('rss.xml');
const manifestHref = withBase('site.webmanifest');
const appleIcon = withBase('apple-touch-icon.png');

// hreflang alternates for every locale + x-default → the default locale home.
const alternates = LOCALES.map((l) => ({ hreflang: l, href: localeUrl(l, origin) }));

// Cloudflare Web Analytics — privacy-friendly, cookieless. Only injected when a token is
// provided, so dev/forks ship no beacon and no consent banner is needed.
const cfToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

// One JSON-LD @graph: the app, the org, and the FAQ (unlocks the FAQ rich result).
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${origin.origin}/#org`,
      name: SITE.name,
      url: SITE.domain,
      logo: new URL(favicon, origin).href,
    },
    {
      '@type': 'SoftwareApplication',
      name: SITE.name,
      applicationCategory: 'EducationApplication',
      operatingSystem: 'iOS, Android, Web',
      description: pageDesc,
      url: canonical,
      publisher: { '@id': `${origin.origin}/#org` },
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      inLanguage: locale,
      mainEntity: t.faq.items.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={localeUrl(DEFAULT_LOCALE, origin)} />
    <meta name="theme-color" content="#0b0b0d" />
    <meta name="color-scheme" content="dark" />

    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="mask-icon" href={favicon} color="#ff6a2b" />
    <link rel="apple-touch-icon" href={appleIcon} />
    <link rel="manifest" href={manifestHref} />
    <link rel="sitemap" href={sitemapHref} />
    <link rel="alternate" type="application/rss+xml" title="Mentara Blog" href={rssHref} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={t.ogLocale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    {
      cfToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token":"${cfToken}","spa":true}`}
        />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip">{t.a11ySkip}</a>
    <slot />
    <style>
      .skip {
        position: absolute;
        left: -999px;
        top: 0.75rem;
        z-index: 100;
        background: var(--amber);
        color: var(--ink);
        padding: 0.6rem 1rem;
        border-radius: 0 0 10px 0;
        font-family: var(--font-mono);
        font-size: 0.8rem;
      }
      .skip:focus {
        left: 0;
      }
    </style>
  </body>
</html>
