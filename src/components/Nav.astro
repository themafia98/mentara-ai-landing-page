---
import { NAV_LINKS, SITE } from '../consts';
---

<header class="nav">
  <div class="container nav__row">
    <a href="#main" class="brand" aria-label={`${SITE.name} home`}>
      <span class="brand__mark" aria-hidden="true">M</span>
      <span class="brand__word">{SITE.name}</span>
      <span class="brand__tag">~/interview</span>
    </a>

    <nav class="links" aria-label="Primary">
      {NAV_LINKS.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <span class="pill" aria-label={SITE.launchLabel}>
      <span class="dot" aria-hidden="true"></span>
      {SITE.launchLabel}
    </span>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px) saturate(140%);
    background: color-mix(in oklab, var(--ink) 72%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .nav__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.4rem;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .brand__mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--ink);
    background: var(--amber);
    width: 1.85rem;
    height: 1.85rem;
    display: grid;
    place-items: center;
    border-radius: 8px;
    transform: translateY(0.25rem);
  }
  .brand__word {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
  }
  .brand__tag {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--bone-faint);
  }
  .links {
    display: flex;
    gap: 2rem;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    color: var(--bone-dim);
  }
  .links a {
    position: relative;
    padding-block: 0.3rem;
    transition: color 0.2s;
  }
  .links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background: var(--amber);
    transition: width 0.28s var(--ease);
  }
  .links a:hover {
    color: var(--bone);
  }
  .links a:hover::after {
    width: 100%;
  }
  @media (max-width: 820px) {
    .links {
      display: none;
    }
  }
  @media (max-width: 520px) {
    .brand__tag {
      display: none;
    }
  }
</style>
