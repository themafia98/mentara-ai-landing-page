---
import { WAITLIST } from '../consts';

interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
const enabled = WAITLIST.endpoint.length > 0;
---

<div class:list={['wl-wrap', { 'wl-wrap--compact': compact }]}>
  {
    enabled ? (
      <form
        class="wl"
        action={WAITLIST.endpoint}
        method="POST"
        data-success={WAITLIST.success}
        data-error={WAITLIST.error}
      >
        <label class="wl__label" for={`wl-${compact ? 'b' : 'a'}`}>
          Email address
        </label>
        <div class="wl__row">
          <input
            id={`wl-${compact ? 'b' : 'a'}`}
            class="wl__input"
            type="email"
            name="email"
            required
            autocomplete="email"
            inputmode="email"
            placeholder={WAITLIST.placeholder}
          />
          <button class="btn wl__btn" type="submit">
            {WAITLIST.cta}
          </button>
        </div>
        {/* Honeypot — bots fill it, humans never see it. */}
        <input
          class="wl__hp"
          type="text"
          name="_gotcha"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />
        <p class="wl__status" role="status" aria-live="polite" />
      </form>
    ) : (
      <div class="wl wl--off" role="note">
        <span class="wl__label">Waitlist</span>
        <p class="wl__offmsg">
          Opens shortly — set <code>PUBLIC_FORMSPREE_ENDPOINT</code> to enable the form.
        </p>
      </div>
    )
  }
</div>

<script is:inline>
  // Progressive enhancement: async submit + inline status, no page leave. Without JS the
  // native POST still works (Formspree shows its own confirmation).
  document.querySelectorAll('form.wl').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector('.wl__status');
      const btn = form.querySelector('.wl__btn');
      btn.disabled = true;
      status.textContent = 'Sending…';
      status.dataset.state = 'pending';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          status.textContent = form.dataset.success;
          status.dataset.state = 'ok';
        } else {
          throw new Error('bad status');
        }
      } catch {
        status.textContent = form.dataset.error;
        status.dataset.state = 'err';
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  .wl-wrap {
    width: 100%;
    max-width: 30rem;
  }
  .wl-wrap--compact {
    max-width: 26rem;
  }
  .wl__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bone-faint);
    margin-bottom: 0.55rem;
  }
  .wl__row {
    display: flex;
    gap: 0.6rem;
  }
  .wl__input {
    flex: 1;
    min-width: 0;
    background: var(--ink-2);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    color: var(--bone);
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.85rem 1.2rem;
    transition: border-color 0.2s var(--ease);
  }
  .wl__input::placeholder {
    color: var(--bone-faint);
  }
  .wl__input:focus-visible {
    outline: none;
    border-color: var(--amber);
  }
  .wl__btn {
    white-space: nowrap;
  }
  .wl__btn:disabled {
    opacity: 0.6;
    cursor: progress;
  }
  .wl__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .wl__status {
    min-height: 1.2rem;
    margin-top: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--bone-dim);
  }
  .wl__status[data-state='ok'] {
    color: var(--sage);
  }
  .wl__status[data-state='err'] {
    color: var(--amber);
  }
  .wl--off {
    border: 1px dashed var(--line-strong);
    border-radius: 14px;
    padding: 1rem 1.2rem;
  }
  .wl__offmsg {
    color: var(--bone-faint);
    font-size: 0.85rem;
    margin-top: 0.3rem;
  }
  .wl__offmsg code {
    font-family: var(--font-mono);
    color: var(--bone-dim);
  }
  @media (max-width: 460px) {
    .wl__row {
      flex-direction: column;
    }
    .wl__btn {
      justify-content: center;
    }
  }
</style>
