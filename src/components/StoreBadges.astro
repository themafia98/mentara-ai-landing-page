---
// "Coming soon" availability badges (iOS / Android / Web). Intentionally non-interactive
// (no links yet) and announced to assistive tech as unavailable.
import { getDict, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const b = getDict(locale).badges;
---

<div class="badges" role="group" aria-label={b.ariaGroup}>
  <div class="badge" aria-disabled="true">
    <svg viewBox="0 0 24 24" aria-hidden="true" class="badge__glyph">
      <path
        fill="currentColor"
        d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.3.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
      ></path>
    </svg>
    <span class="badge__text">
      <small>{b.comingSoon}</small>
      <strong>{b.ios}</strong>
    </span>
  </div>

  <div class="badge" aria-disabled="true">
    <svg viewBox="0 0 24 24" aria-hidden="true" class="badge__glyph">
      <path
        fill="currentColor"
        d="M3 20.5v-17C3 2.91 3.34 2.39 3.84 2.15L13.69 12 3.84 21.85C3.34 21.6 3 21.09 3 20.5zm13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27zM20.16 10.81C20.5 11.08 20.75 11.5 20.75 12s-.25.92-.59 1.19L17.89 14.5 15.39 12l2.5-2.5 2.27 1.31zM6.05 2.66l10.76 6.22-2.27 2.27L6.05 2.66z"
      ></path>
    </svg>
    <span class="badge__text">
      <small>{b.comingSoon}</small>
      <strong>{b.android}</strong>
    </span>
  </div>

  <div class="badge" aria-disabled="true">
    <svg viewBox="0 0 24 24" aria-hidden="true" class="badge__glyph">
      <path
        fill="currentColor"
        d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm6.9 6h-3a15.7 15.7 0 0 0-1.4-3.6A8 8 0 0 1 18.9 8zM12 4c.8 1.1 1.5 2.5 1.9 4h-3.8C10.5 6.5 11.2 5.1 12 4zM4.3 14a8 8 0 0 1 0-4h3.4a17 17 0 0 0 0 4zm.8 2h3a15.7 15.7 0 0 0 1.4 3.6A8 8 0 0 1 5.1 16zm3-8h-3a8 8 0 0 1 4.4-3.6A15.7 15.7 0 0 0 8.1 8zM12 20c-.8-1.1-1.5-2.5-1.9-4h3.8c-.4 1.5-1.1 2.9-1.9 4zm2.3-6H9.7a15 15 0 0 1 0-4h4.6a15 15 0 0 1 0 4zm.3 5.6A15.7 15.7 0 0 0 16 16h3a8 8 0 0 1-4.4 3.6zM16.3 14a17 17 0 0 0 0-4h3.4a8 8 0 0 1 0 4z"
      ></path>
    </svg>
    <span class="badge__text">
      <small>{b.comingSoon}</small>
      <strong>{b.web}</strong>
    </span>
  </div>
</div>

<style>
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  /* Three "coming soon" badges. flex-basis gives a tidy row; min-width:0 lets them
     shrink/wrap WITHIN the column instead of overflowing it – `min-width:max-content`
     here previously forced the row to bleed over the hero panel in longer locales. */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    flex: 1 1 8.5rem;
    min-width: 0;
    padding: 0.6rem 0.95rem;
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    background: rgba(236, 231, 221, 0.02);
    color: var(--bone);
    cursor: not-allowed;
    user-select: none;
    transition: border-color 0.25s var(--ease);
  }
  .badge:hover {
    border-color: var(--bone-faint);
  }
  .badge__glyph {
    width: 1.4rem;
    height: 1.4rem;
    color: var(--bone-dim);
    flex: none;
  }
  .badge__text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .badge__text small {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bone-faint);
  }
  .badge__text strong {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.98rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
</style>
