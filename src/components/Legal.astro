---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDict, localeHome, type Locale } from '../i18n';
import { LEGAL_DOCS, LEGAL_EFFECTIVE_DATE, type LegalDoc } from '../legal';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

interface Props {
  locale: Locale;
  doc: LegalDoc;
}
const { locale, doc } = Astro.props;
const t = getDict(locale);
const title = doc === 'privacy' ? t.legal.privacyTitle : t.legal.termsTitle;
const sections = LEGAL_DOCS[doc];
---

<BaseLayout locale={locale} title={`${title} — Mentara`} description={t.legal.draftNotice}>
  <Nav locale={locale} homeHref={localeHome(locale)} />
  <main id="main" class="legal">
    <div class="container legal__inner">
      <a class="legal__back" href={localeHome(locale)}>← {t.legal.back}</a>
      <h1 class="h2">{title}</h1>
      <p class="legal__notice" role="note">{t.legal.draftNotice}</p>

      {
        sections.map((s) => (
          <section class="legal__section">
            <h2>{s.heading}</h2>
            {s.body.map((p) => (
              <p>{p}</p>
            ))}
          </section>
        ))
      }

      <p class="legal__updated mono">
        {t.legal.updated}: <time datetime={LEGAL_EFFECTIVE_DATE}>{LEGAL_EFFECTIVE_DATE}</time>
      </p>
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .legal {
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .legal__inner {
    max-width: 56rem;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .legal__back {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--bone-dim);
    align-self: flex-start;
    transition: color 0.2s;
  }
  .legal__back:hover {
    color: var(--amber);
  }
  .legal__notice {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--amber);
    border: 1px solid color-mix(in oklab, var(--amber) 40%, transparent);
    border-radius: var(--radius);
    padding: 0.9rem 1.1rem;
    background: color-mix(in oklab, var(--amber) 8%, var(--ink-1));
  }
  .legal__section {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
  }
  .legal__section h2 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .legal__section p {
    color: var(--bone-dim);
    line-height: 1.65;
  }
  .legal__updated {
    margin-top: 1rem;
    color: var(--bone-faint);
  }
</style>
