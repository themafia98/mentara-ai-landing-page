---
import { getDict, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const items = getDict(locale).trust;
---

<div class="trust">
  <div class="container trust__row">
    {
      items.map((item) => (
        <span class="trust__item">
          <span class="trust__tick" aria-hidden="true">›</span>
          {item}
        </span>
      ))
    }
  </div>
</div>

<style>
  .trust {
    border-block: 1px solid var(--line);
    background: rgba(0, 0, 0, 0.22);
  }
  .trust__row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2.4rem;
    padding-block: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--bone-dim);
    text-transform: uppercase;
  }
  .trust__item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }
  .trust__tick {
    color: var(--amber);
  }
</style>
