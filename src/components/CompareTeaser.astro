---
import type { Locale } from '../i18n';
import { getDict, localePath } from '../i18n';
import { getPublishedPosts, postsForSlugs, getCluster } from '../content/blog';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDict(locale);

const compareCluster = getCluster('compare');
const posts = await getPublishedPosts();
const comparePosts =
  compareCluster == null ? [] : postsForSlugs(posts, compareCluster.slugs).slice(0, 3);
---

<section class="compare-teaser" aria-labelledby="compare-teaser-title">
  <div class="container compare-teaser__grid">
    <div class="compare-teaser__copy">
      <p class="eyebrow">{t.contentHub.compare.eyebrow}</p>
      <h2 id="compare-teaser-title" class="h2">{t.contentHub.compare.title}</h2>
      <p class="compare-teaser__lede">{t.contentHub.compare.lede}</p>
      <div class="compare-teaser__actions">
        <a href={localePath(locale, 'compare')} class="compare-teaser__primary">
          {t.contentHub.compare.primary}
        </a>
        <a href={localePath(locale, 'resources')} class="compare-teaser__secondary">
          {t.contentHub.compare.secondary}
        </a>
      </div>
    </div>

    <div class="compare-teaser__stack">
      {
        comparePosts.map((post) => (
          <article class="compare-teaser__card">
            <a href={localePath(locale, `blog/${post.id}`)}>
              <h3>{post.data.title}</h3>
              <p>{post.data.summary}</p>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .compare-teaser {
    padding-block: clamp(4rem, 8vw, 7rem);
  }
  .compare-teaser__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }
  .compare-teaser__copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .compare-teaser__lede {
    color: var(--bone-dim);
    line-height: 1.7;
    max-width: 40rem;
  }
  .compare-teaser__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.35rem;
  }
  .compare-teaser__primary,
  .compare-teaser__secondary {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--line-strong);
  }
  .compare-teaser__primary {
    background: var(--amber);
    color: var(--ink);
    border-color: color-mix(in oklab, var(--amber) 70%, transparent);
  }
  .compare-teaser__secondary {
    color: var(--bone);
  }
  .compare-teaser__stack {
    display: grid;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .compare-teaser__card {
    background: var(--ink);
  }
  .compare-teaser__card a {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.2rem 1.15rem;
  }
  .compare-teaser__card h3 {
    font-family: var(--font-display);
    font-size: 1.16rem;
    letter-spacing: -0.02em;
  }
  .compare-teaser__card p {
    color: var(--bone-dim);
    line-height: 1.6;
  }
  .compare-teaser__card a:hover h3 {
    color: var(--amber);
  }
  @media (max-width: 920px) {
    .compare-teaser__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
