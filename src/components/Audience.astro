---
import { AUDIENCE } from '../consts';
const { groups, versus } = AUDIENCE;
---

<section id="audience">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">{AUDIENCE.eyebrow}</p>
      <h2 class="h2">{AUDIENCE.heading}</h2>
    </div>

    <div class="who-grid">
      {
        groups.map((g) => (
          <article class="who-card">
            <span class="who-card__tag">{g.tag}</span>
            <p>{g.body}</p>
          </article>
        ))
      }
    </div>

    <div class="vs" aria-label={`${versus.them} versus ${versus.us}`}>
      <div class="vs__col vs__col--them">
        <span class="vs__name">{versus.them}</span>
        <ul>
          {
            versus.themPoints.map((p) => (
              <li>
                <span class="vs__mark vs__mark--x" aria-hidden="true">
                  ✕
                </span>
                {p}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="vs__col vs__col--us">
        <span class="vs__name">{versus.us}</span>
        <ul>
          {
            versus.usPoints.map((p) => (
              <li>
                <span class="vs__mark vs__mark--c" aria-hidden="true">
                  ✓
                </span>
                {p}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .who-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .who-card {
    padding: clamp(1.5rem, 3vw, 2.2rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--ink-1);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .who-card__tag {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid color-mix(in oklab, var(--amber) 40%, transparent);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
  }
  .who-card p {
    color: var(--bone-dim);
    line-height: 1.6;
  }

  .vs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .vs__col {
    padding: clamp(1.6rem, 3.5vw, 2.6rem);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .vs__col--them {
    background: var(--ink-1);
    border-right: 1px solid var(--line);
  }
  .vs__col--us {
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--amber) 8%, var(--ink-1)),
      var(--ink-1)
    );
  }
  .vs__name {
    font-family: var(--font-display);
    font-weight: 620;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }
  .vs__col--them .vs__name {
    color: var(--bone-dim);
  }
  .vs__col--us .vs__name {
    color: var(--amber);
  }
  .vs ul {
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }
  .vs li {
    display: flex;
    gap: 0.7rem;
    font-size: 0.95rem;
    color: var(--bone);
    line-height: 1.45;
  }
  .vs__mark {
    flex: none;
    font-size: 0.85rem;
    padding-top: 0.1rem;
  }
  .vs__mark--x {
    color: var(--bone-faint);
  }
  .vs__mark--c {
    color: var(--amber);
  }
  @media (max-width: 820px) {
    .who-grid {
      grid-template-columns: 1fr;
    }
    .vs {
      grid-template-columns: 1fr;
    }
    .vs__col--them {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
  }
</style>
