---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import type { Locale } from '../i18n';
import { getDict } from '../i18n';
import { getPublishedPosts, formatPostDate, clustersWithPosts } from '../content/blog';
import { localePath, localeHome } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDict(locale);

const posts = await getPublishedPosts();
const readingPaths = clustersWithPosts(posts);
---

<BaseLayout
  locale={locale}
  title={`${t.contentHub.blog.eyebrow} – Mentara`}
  description={t.contentHub.blog.lede}
>
  <Nav locale={locale} homeHref={localeHome(locale)} />
  <main id="main" class="blog">
    <div class="container blog__inner">
      <p class="eyebrow">{t.contentHub.blog.eyebrow}</p>
      <h1 class="h2">{t.contentHub.blog.title}</h1>
      <p class="blog__intro">{t.contentHub.blog.lede}</p>
      <div class="blog__links">
        <a href={localePath(locale, 'resources')} class="blog__hub">{t.contentHub.blog.primary} →</a>
        <a href={localePath(locale, 'compare')} class="blog__hub">{t.contentHub.compare.primary}</a>
      </div>

      <section class="paths" aria-labelledby="paths-title">
        <div class="paths__head">
          <p class="eyebrow">{t.contentHub.blog.pathsEyebrow}</p>
          <h2 id="paths-title" class="h3">{t.contentHub.blog.pathsTitle}</h2>
        </div>

        <div class="paths__grid">
          {
            readingPaths.map((path) => (
              <section class="path">
                <h3 class="path__title">{path.title}</h3>
                <p class="path__lede">{path.lede}</p>
                <ul class="path__list">
                  {path.posts.map((post) => (
                    <li>
                      <a href={localePath(locale, `blog/${post.id}`)}>{post.data.title}</a>
                    </li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </section>

      <ul class="posts">
        {
          posts.map((p) => (
            <li class="post">
              <a href={localePath(locale, `blog/${p.id}`)} class="post__link">
                <time class="post__date mono" datetime={p.data.date.toISOString()}>
                  {formatPostDate(p.data.date)}
                </time>
                <h2 class="post__title">{p.data.title}</h2>
                <p class="post__sum">{p.data.summary}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .blog {
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .blog__inner {
    max-width: 52rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .posts {
    list-style: none;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
  }
  .blog__links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .blog__hub {
    font-family: var(--font-mono);
    color: var(--amber);
  }
  .paths {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--ink-2) 62%, transparent);
  }
  .paths__head {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .paths__grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .path {
    padding: 1rem;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--ink) 38%, transparent);
  }
  .path__title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }
  .path__lede {
    margin-top: 0.45rem;
    color: var(--bone-dim);
    line-height: 1.6;
  }
  .path__list {
    margin-top: 0.8rem;
    padding-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    color: var(--bone-dim);
  }
  .path__list a:hover {
    color: var(--amber);
  }
  .blog__intro {
    color: var(--bone-dim);
    line-height: 1.7;
    max-width: 44rem;
  }
  .post {
    border-top: 1px solid var(--line);
  }
  .post:last-child {
    border-bottom: 1px solid var(--line);
  }
  .post__link {
    display: block;
    padding: 1.6rem 0;
    transition: opacity 0.2s;
  }
  .post__link:hover {
    opacity: 0.85;
  }
  .post__date {
    color: var(--amber);
  }
  .post__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0.4rem 0;
  }
  .post__sum {
    color: var(--bone-dim);
    line-height: 1.6;
  }
  @media (max-width: 820px) {
    .paths__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
