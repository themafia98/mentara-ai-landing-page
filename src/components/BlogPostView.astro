---
import { render } from 'astro:content';
import type { Locale } from '../i18n';
import { localePath, localeHome, withBase } from '../i18n';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import { findClusterBySlug } from '../content/blog-clusters';
import { getPublishedPosts, formatPostDate, type BlogPost } from '../content/blog';

interface Props {
  locale: Locale;
  post: BlogPost;
}
const { locale, post } = Astro.props;
const { Content } = await render(post);
const cluster = findClusterBySlug(post.id);
const publishedPosts = await getPublishedPosts();
const relatedPosts =
  cluster == null
    ? []
    : publishedPosts
        .filter((candidate) => cluster.slugs.includes(candidate.id) && candidate.id !== post.id)
        .sort((a, b) => cluster.slugs.indexOf(a.id) - cluster.slugs.indexOf(b.id))
        .slice(0, 4);
const clusterCta = cluster?.cta ?? null;
const fmt = formatPostDate(post.data.date, 'long');
---

<BaseLayout locale={locale} title={`${post.data.title} – Mentara`} description={post.data.summary}>
  <Nav locale={locale} homeHref={localeHome(locale)} />
  <main id="main" class="post">
    <article class="container post__inner">
      <a class="post__back" href={localePath(locale, 'blog')}>← Blog</a>
      <time class="post__date mono" datetime={post.data.date.toISOString()}>{fmt}</time>
      <h1 class="h2">{post.data.title}</h1>
      <div class="prose">
        <Content />
      </div>
      {
        relatedPosts.length > 0 && (
          <aside class="related">
            <p class="related__eyebrow mono">Related reading</p>
            <h2 class="related__title">{cluster?.title}</h2>
            <ul class="related__list">
              {relatedPosts.map((relatedPost) => (
                <li>
                  <a href={localePath(locale, `blog/${relatedPost.id}`)}>{relatedPost.data.title}</a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
      {
        clusterCta != null && (
          <section class="article-cta">
            <p class="article-cta__eyebrow">{clusterCta.eyebrow}</p>
            <h2 class="article-cta__title">{clusterCta.title}</h2>
            <p class="article-cta__body">{clusterCta.body}</p>
            <div class="article-cta__actions">
              <a class="article-cta__primary" href={withBase(clusterCta.primaryHref)}>
                {clusterCta.primaryLabel}
              </a>
              {
                clusterCta.secondaryLabel &&
                  clusterCta.secondaryHref && (
                    <a class="article-cta__secondary" href={withBase(clusterCta.secondaryHref)}>
                      {clusterCta.secondaryLabel}
                    </a>
                  )
              }
            </div>
          </section>
        )
      }
    </article>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .post {
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .post__inner {
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .post__back {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--bone-dim);
    align-self: flex-start;
  }
  .post__back:hover {
    color: var(--amber);
  }
  .post__date {
    color: var(--amber);
  }
  .prose {
    margin-top: 1rem;
    color: var(--bone-dim);
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 600;
    color: var(--bone);
    letter-spacing: -0.02em;
    margin-top: 1rem;
  }
  .prose :global(ul) {
    padding-left: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose :global(a) {
    color: var(--amber);
    text-decoration: underline;
  }
  .prose :global(strong) {
    color: var(--bone);
  }
  .related {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }
  .related__eyebrow {
    color: var(--amber);
    font-size: 0.78rem;
  }
  .related__title {
    margin-top: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: -0.02em;
  }
  .related__list {
    margin-top: 0.8rem;
    padding-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    color: var(--bone-dim);
  }
  .related__list a:hover {
    color: var(--amber);
  }
  .article-cta {
    margin-top: 1.6rem;
    padding: 1.4rem;
    border: 1px solid color-mix(in oklab, var(--amber) 28%, transparent);
    background:
      radial-gradient(circle at top right, color-mix(in oklab, var(--amber) 10%, transparent), transparent 35%),
      color-mix(in oklab, var(--ink-2) 58%, transparent);
  }
  .article-cta__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--amber);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .article-cta__title {
    margin-top: 0.4rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: -0.02em;
  }
  .article-cta__body {
    margin-top: 0.55rem;
    color: var(--bone-dim);
    line-height: 1.65;
  }
  .article-cta__actions {
    margin-top: 0.95rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
  .article-cta__primary,
  .article-cta__secondary {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    padding: 0.78rem 0.95rem;
    border: 1px solid var(--line-strong);
  }
  .article-cta__primary {
    background: var(--amber);
    color: var(--ink);
    border-color: color-mix(in oklab, var(--amber) 70%, transparent);
  }
  .article-cta__secondary {
    color: var(--bone);
  }
</style>
