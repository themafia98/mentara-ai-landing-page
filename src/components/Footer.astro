---
import { SITE } from '../consts';
import { getDict, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDict(locale);
const year = new Date().getFullYear();
---

<footer class="foot">
  <div class="container foot__grid">
    <div class="foot__brand">
      <a href="#main" class="foot__word">{SITE.name}</a>
      <p class="mono">{t.footer.blurb}</p>
    </div>

    <nav class="foot__nav" aria-label="Footer">
      <span class="foot__label">{t.footer.explore}</span>
      {t.nav.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="foot__nav">
      <span class="foot__label">{t.footer.legal}</span>
      <span class="foot__muted">{t.footer.legalMuted}</span>
    </div>
  </div>

  <div class="container foot__base">
    <span class="mono">© {year} {SITE.name}</span>
    <span class="mono">{t.meta.launchLabel}</span>
  </div>
</footer>

<style>
  .foot {
    border-top: 1px solid var(--line);
    background: rgba(0, 0, 0, 0.3);
    padding-block: clamp(3rem, 6vw, 5rem) 2rem;
  }
  .foot__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .foot__word {
    font-family: var(--font-display);
    font-weight: 680;
    font-size: 1.6rem;
    letter-spacing: -0.02em;
  }
  .foot__brand .mono {
    margin-top: 0.7rem;
  }
  .foot__nav {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    font-size: 0.95rem;
    color: var(--bone-dim);
  }
  .foot__nav a {
    transition: color 0.2s;
  }
  .foot__nav a:hover {
    color: var(--amber);
  }
  .foot__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--bone-faint);
    margin-bottom: 0.3rem;
  }
  .foot__muted {
    color: var(--bone-faint);
    font-size: 0.9rem;
  }
  .foot__base {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
  }
  @media (max-width: 720px) {
    .foot__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
