---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import type { Locale } from '../i18n';
import { getDict } from '../i18n';
import { getPublishedPosts, clustersWithPosts } from '../content/blog';
import { localePath, localeHome } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDict(locale);

const posts = await getPublishedPosts();
const clusters = clustersWithPosts(posts);
---

<BaseLayout
  locale={locale}
  title={`${t.contentHub.resources.eyebrow} — Mentara`}
  description={t.contentHub.resources.lede}
>
  <Nav locale={locale} homeHref={localeHome(locale)} />
  <main id="main" class="hub">
    <div class="container hub__inner">
      <p class="eyebrow">{t.contentHub.resources.eyebrow}</p>
      <h1 class="h2">{t.contentHub.resources.title}</h1>
      <p class="hub__intro">{t.contentHub.resources.lede}</p>

      <div class="hub__grid">
        {
          clusters.map((cluster) => (
            <section class="cluster">
              <h2 class="cluster__title">{cluster.title}</h2>
              <p class="cluster__lede">{cluster.lede}</p>
              <ul class="cluster__list">
                {cluster.posts.map((post) => (
                  <li class="cluster__item">
                    <a href={localePath(locale, `blog/${post.id}`)}>
                      <strong>{post.data.title}</strong>
                      <span>{post.data.summary}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .hub {
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .hub__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .hub__intro {
    color: var(--bone-dim);
    line-height: 1.7;
    max-width: 46rem;
  }
  .hub__grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .cluster {
    border: 1px solid var(--line);
    padding: 1.2rem;
    background: color-mix(in oklab, var(--ink-2) 52%, transparent);
  }
  .cluster__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: -0.02em;
  }
  .cluster__lede {
    margin-top: 0.5rem;
    color: var(--bone-dim);
    line-height: 1.65;
  }
  .cluster__list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    list-style: none;
  }
  .cluster__item a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .cluster__item strong {
    color: var(--bone);
  }
  .cluster__item span {
    color: var(--bone-dim);
    line-height: 1.55;
  }
  .cluster__item a:hover strong {
    color: var(--amber);
  }
  @media (max-width: 860px) {
    .hub__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
