---
import { getDict, type Locale } from '../i18n';
import SectionHead from './SectionHead.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const f0 = getDict(locale).features;
---

<section id="features">
  <div class="container">
    <SectionHead eyebrow={f0.eyebrow} heading={f0.heading} />

    <div class="grid">
      {
        f0.items.map((f) => (
          <article class="feat">
            <span class="feat__idx" aria-hidden="true">
              {f.index}
            </span>
            <div class="feat__main">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .feat {
    display: flex;
    gap: 1.4rem;
    padding: clamp(1.8rem, 3.5vw, 3rem);
    background: var(--ink);
    transition: background 0.3s var(--ease);
  }
  .feat:hover {
    background: var(--ink-1);
  }
  .feat__idx {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--amber);
    padding-top: 0.45rem;
    letter-spacing: 0.1em;
  }
  .feat__main h3 {
    font-size: 1.5rem;
    margin-bottom: 0.7rem;
  }
  .feat__main p {
    color: var(--bone-dim);
    max-width: 42ch;
    line-height: 1.6;
  }
  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
