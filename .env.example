# Copy to .env (and set the same vars as GitHub Actions repo variables for the deploy
# workflow). All are PUBLIC_ — they are inlined into the static build, never put secrets
# here (the Firebase deploy service-account key is a GitHub Actions *secret*, not an env
# var — see .github/workflows/deploy.yml).

# Formspree form endpoint for the waitlist. A live default is committed in src/consts.ts,
# so this is OPTIONAL — set it only to override (e.g. a staging form).
PUBLIC_FORMSPREE_ENDPOINT=

# Cloudflare Web Analytics beacon token (Dashboard → Web Analytics → your site → token).
# Empty = no analytics beacon is injected (and no cookie banner is needed).
PUBLIC_CF_BEACON_TOKEN=

# Hosting overrides (defaults target Firebase Hosting at the mentara.ai custom domain).
# To build/preview against the auto-assigned Firebase domain instead, set:
# SITE_URL=https://mentara-ai-landing.web.app and BASE_PATH=/
# SITE_URL=
# BASE_PATH=
