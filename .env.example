# Copy to .env (and set the same vars in the GitHub Pages Action env / repo variables).
# All are PUBLIC_ — they are inlined into the static build, never put secrets here.

# Formspree form endpoint for the waitlist. Create a form at https://formspree.io,
# then paste its endpoint. Empty = the waitlist renders a disabled placeholder.
PUBLIC_FORMSPREE_ENDPOINT=

# Cloudflare Web Analytics beacon token (Dashboard → Web Analytics → your site → token).
# Empty = no analytics beacon is injected (and no cookie banner is needed).
PUBLIC_CF_BEACON_TOKEN=

# Hosting overrides (defaults target GitHub Pages for this project repo).
# For a custom domain set: SITE_URL=https://mentara.ai and BASE_PATH=/
# SITE_URL=
# BASE_PATH=
